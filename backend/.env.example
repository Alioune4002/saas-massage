DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000
DATABASE_URL=
DJANGO_ENABLE_WHITENOISE=true
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=false

DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=NUADYX <bonjour@nuadyx.app>
DJANGO_EMAIL_HOST=smtp.example.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=true

FRONTEND_APP_URL=http://localhost:3000

NUADYX_STRIPE_SECRET_KEY=
NUADYX_STRIPE_PUBLISHABLE_KEY=
NUADYX_STRIPE_WEBHOOK_SECRET=
NUADYX_STRIPE_INTERNAL_TEST_MODE=false

NUADYX_PLATFORM_FEE_RATE=0.10
NUADYX_PAYMENT_HOLD_MINUTES=30
NUADYX_AUTO_RELEASE_AFTER_HOURS=48
